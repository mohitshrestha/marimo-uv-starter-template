{% macro render_group(title, items, type) %}
<!-- Macro to render a group of notebooks or apps -->
<h2 class="section-title">
  {{ title }}{% if type %} - {{ type|capitalize }}{% endif %}
</h2>

<!-- The container for displaying the cards (each representing a notebook or app) -->
<div class="cards">
  {% for item in items %}
    <!-- Each individual card for a notebook/app -->
    <div class="card">
      
      <!-- Card header displaying the name of the notebook/app -->
      <div class="card-header {% if type == 'app' %}app{% endif %}">
        {{ item.display_name }}
      </div>
      
      <!-- Card body with a link to open the notebook/app -->
      <div class="card-body">
        <a href="{{ item.html_path }}" class="card-link {% if type == 'app' %}app{% endif %}">
          Open {% if type %}{{ type|capitalize }}{% else %}Notebook{% endif %}
        </a>
      </div>
    </div>
  {% endfor %}
</div>
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>marimo WebAssembly + GitHub Pages Template</title>

  <!-- Inline styling for the template -->
  <style>
    /* General body styling */
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      background-color: #fff;
      padding: 20px;
      margin: 0;
    }

    /* Container for the page content */
    .container {
      max-width: 1000px;
      margin: 0 auto;
    }

    /* Header styling */
    header {
      background-color: #f0f0f0;
      padding: 20px;
      text-align: center;
      margin-bottom: 20px;
    }

    /* Logo styling */
    .logo {
      width: 80px;
      height: auto;
      margin-bottom: 10px;
    }

    /* Main heading (title) styling */
    h1 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    /* Subtitle styling */
    .subtitle {
      font-size: 16px;
      margin: 0 auto;
    }

    /* Section title for categories of notebooks/apps */
    .section-title {
      font-size: 20px;
      margin: 20px 0 10px;
      text-align: center;
    }

    /* Cards container for displaying items in a grid */
    .cards {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin: 20px 0;
    }

    /* Individual card styling */
    .card {
      background-color: #f9f9f9;
      border: 1px solid #ddd;
      flex: 1 0 200px;
    }

    /* Card header (displaying the title of the notebook/app) */
    .card-header {
      background-color: #ddd;
      padding: 10px;
      font-weight: bold;
    }

    /* Special styling for app headers (slightly lighter background) */
    .card-header.app {
      background-color: #eee;
    }

    /* Card body styling (content of the card) */
    .card-body {
      padding: 15px;
    }

    /* Link styling within the card */
    .card-link {
      display: inline-block;
      background-color: #4a86e8;
      color: white;
      padding: 5px 10px;
      text-decoration: none;
    }

    /* Special link styling for apps (orange color) */
    .card-link.app {
      background-color: #ff9900;
    }

    /* Footer styling */
    footer {
      background-color: #f0f0f0;
      text-align: center;
      padding: 20px 0;
      margin-top: 30px;
    }

    /* Links in the footer */
    .footer-links a {
      color: #4a86e8;
      margin: 0 10px;
      text-decoration: none;
    }
  </style>
</head>
<body class="font-sans max-w-2xl mx-auto p-8 leading-relaxed">

    <!-- Header section of the page -->
    <header>
      <div class="container">
        <!-- Logo image -->
        <img src="https://raw.githubusercontent.com/marimo-team/marimo/main/docs/_static/marimo-logotype-thick.svg" 
             alt="marimo Logo" class="logo">
        
        <!-- Main heading -->
        <h1>marimo WebAssembly + GitHub Pages Template</h1>
        
        <!-- Subtitle providing a brief description -->
        <p class="subtitle">Interactive Python notebooks exported to WebAssembly and deployed to GitHub Pages</p>
      </div>
    </header>

    <!-- Main content area where notebooks and apps will be listed -->
    <main class="container">

      {% if notebooks %}
        <!-- Loop through each category of notebooks and render them using the render_group macro -->
        {% for category, items in notebooks.items() %}
          {{ render_group(category, items, 'notebook') }}
        {% endfor %}
      {% endif %}

      {% if apps %}
        <!-- Loop through each category of apps and render them using the render_group macro -->
        {% for category, items in apps.items() %}
          {{ render_group(category, items, 'app') }}
        {% endfor %}
      {% endif %}

    </main>

    <!-- Footer section of the page -->
    <footer>
      <div class="container">
        <!-- Footer text with a link to the Marimo website -->
        <p>Built with <a href="https://marimo.io" target="_blank">marimo</a> - Interactive Python notebooks</p>

        <!-- Footer links to GitHub, Documentation, and Discord -->
        <div class="footer-links">
          <a href="https://github.com/marimo-team/marimo" target="_blank">GitHub</a>
          <a href="https://docs.marimo.io" target="_blank">Documentation</a>
          <a href="https://discord.gg/JE7nhX6mD8" target="_blank">Discord</a>
        </div>

        <!-- License info with a link to the Apache License -->
        <p>Licensed under <a href="https://github.com/marimo-team/marimo/blob/main/LICENSE" target="_blank">Apache License 2.0</a></p>
      </div>
    </footer>

</body>
</html>