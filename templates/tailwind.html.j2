{% macro render_group(title, items, type) %}
<!-- Macro to render a group of notebooks or apps -->
<h2 class="text-xl font-bold text-center my-4">
  {{ title }}{% if type %} - {{ type|capitalize }}{% endif %}
</h2>

<!-- The grid container for the notebooks/apps -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
  {% for item in items %}
    <!-- Each item in the list (notebook or app) -->
    <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
      
      <!-- Item header (name of notebook/app) -->
      <div class="bg-gray-200 p-3 font-semibold {% if type == 'app' %}bg-gray-100{% endif %}">
        {{ item.display_name }}
      </div>

      <!-- Item action button (link to the notebook/app) -->
      <div class="p-4">
        <a href="{{ item.html_path }}" class="inline-block {% if type == 'app' %}bg-amber-500 hover:bg-amber-600{% else %}bg-blue-500 hover:bg-blue-600{% endif %} text-white py-1 px-3 rounded transition-colors">
          Open
        </a>
      </div>
    </div>
  {% endfor %}
</div>
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>marimo WebAssembly + GitHub Pages Template</title>
  
  <!-- Tailwind CSS: Used for styling the layout and components -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans text-gray-800 bg-white p-5">

  <!-- Main container for the entire page -->
  <div class="max-w-4xl mx-auto">

    <!-- Header section of the page -->
    <header class="bg-gray-100 p-6 text-center rounded-lg mb-6">
      
      <!-- Marimo logo -->
      <img src="https://raw.githubusercontent.com/marimo-team/marimo/main/docs/_static/marimo-logotype-thick.svg" 
           alt="marimo Logo" class="w-20 h-auto mx-auto mb-3">
      
      <!-- Main heading -->
      <h1 class="text-2xl font-bold mb-2">marimo WebAssembly + GitHub Pages Template</h1>
      
      <!-- Subheading description -->
      <p class="text-sm">Interactive Python notebooks exported to WebAssembly and deployed to GitHub Pages</p>
    </header>

    <!-- Main content section: where notebooks and apps are listed -->
    <main>
      {% if notebooks %}
        <!-- Loop through each category of notebooks and render them -->
        {% for category, items in notebooks.items() %}
          {{ render_group(category, items, 'notebook') }}
        {% endfor %}
      {% endif %}

      {% if apps %}
        <!-- Loop through each category of apps and render them -->
        {% for category, items in apps.items() %}
          {{ render_group(category, items, 'app') }}
        {% endfor %}
      {% endif %}
    </main>

    <!-- Footer section of the page -->
    <footer class="mt-10 pt-6 border-t border-gray-200 text-center text-sm text-gray-600">
      <p class="mb-2">Built with <a href="https://marimo.io" target="_blank" class="text-blue-500 hover:underline">marimo</a> - Interactive Python notebooks</p>
    </footer>

  </div>

</body>
</html>